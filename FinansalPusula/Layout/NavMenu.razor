<div class="pt-4 px-4 mb-4">
    <div class="d-flex align-items-center h-20">
        <div class="p-1 rounded-3 bg-white bg-opacity-10 me-2" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
            <img src="img/logo-icon.svg" alt="Budget Logo" style="width: 32px; height: 32px; object-fit: contain;" />
        </div>
        <span class="fs-4 fw-bold text-gradient">Budget</span>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column gap-2">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2 text-primary"></i> Ana Sayfa
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="ekstre-yukle">
                <i class="bi bi-receipt-cutoff me-2 text-success"></i> Gider Avcısı (AI)
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="yatirim-takip">
                <i class="bi bi-graph-up-arrow me-2 text-info"></i> Borsa Takibi
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="butce-kalkani">
                <i class="bi bi-shield-lock me-2 text-danger"></i> Bütçe Kalkanı
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="islemler">
                <i class="bi bi-journal-text me-2 text-warning"></i> İşlem Geçmişi
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
