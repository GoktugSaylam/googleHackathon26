@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var normalizedPath = string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";

        if (normalizedPath.StartsWith("/login", StringComparison.OrdinalIgnoreCase)
            || normalizedPath.StartsWith("/authentication", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var encodedReturnUrl = Uri.EscapeDataString(normalizedPath);

        Navigation.NavigateTo($"/login?returnUrl={encodedReturnUrl}", replace: true);
    }
}
