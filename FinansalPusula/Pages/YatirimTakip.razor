@code {
    private string _searchSymbol = "TUPRS.IS";
    private bool _isLoading = false;
    private SimulationResult? _simResult;

    private async Task ExploreStock()
    {
        if (string.IsNullOrWhiteSpace(_searchSymbol)) return;
        
        _isLoading = true;
        StateHasChanged();
        
        try
        {
            var symbol = _searchSymbol.Trim().ToUpper();
            if (!symbol.EndsWith(".IS")) symbol += ".IS";
            
            var history = await InvestmentService.GetHistoricalDataAsync(symbol, DateTime.Today.AddYears(-5), DateTime.Today);
            var detail = await InvestmentService.GetStockDetailAsync(symbol);
            
            if (detail != null && history.Any())
            {
                var relevantTxs = InvestmentService.Transactions.Where(t => t.Symbol == symbol).ToList();
                
                // Eğer hiç işlem yoksa, görseldeki gibi bir demo için 3 yıl öncesine alım ekleyelim
                if (!relevantTxs.Any())
                {
                    relevantTxs.Add(new TransactionRecord 
                    { 
                        Symbol = symbol, 
                        Date = DateTime.Today.AddYears(-3), 
                        Quantity = 1000, 
                        Price = history.FirstOrDefault(h => h.Date >= DateTime.Today.AddYears(-3))?.PriceTL ?? 15.0m 
                    });
                }

                _simResult = PortfolioSimulator.Simulate(
                    symbol, 
                    history, 
                    detail.Dividends, 
                    detail.Splits, 
                    relevantTxs
                );
                
                await Task.Delay(100);
                await RenderCharts();
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ExploreStock();
        }
    }

    private async Task RenderCharts()
    {
        if (_simResult == null) return;

        // Fiyat Grafiği
        var priceConfig = new {
            type = "line",
            data = new {
                labels = _simResult.DailyPoints.Select(p => p.Date.ToString("MM.yy")),
                datasets = new[] {
                    new {
                        label = "Fiyat (TL)",
                        data = _simResult.DailyPoints.Select(p => p.PriceTL),
                        borderColor = "#00d1ff",
                        borderWidth = 2,
                        pointRadius = 0,
                        fill = true,
                        backgroundColor = "rgba(0, 209, 255, 0.05)"
                    }
                }
            },
            options = new {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new {
                    x = new { grid = new { display = false }, ticks = new { color = "rgba(255,255,255,0.3)", maxTicksLimit = 12 } },
                    y = new { grid = new { color = "rgba(255,255,255,0.05)" }, ticks = new { color = "rgba(255,255,255,0.3)" } }
                }
            }
        };

        // Lot Gelişimi Grafiği
        var lotConfig = new {
            type = "bar",
            data = new {
                labels = _simResult.DailyPoints.Where((p, i) => i % 30 == 0).Select(p => p.Date.ToString("yyyy")),
                datasets = new[] {
                    new {
                        label = "Toplam Lot",
                        data = _simResult.DailyPoints.Where((p, i) => i % 30 == 0).Select(p => _simResult.TotalLots), // Mock logic for growth steps
                        backgroundColor = "#30d158"
                    }
                }
            },
            options = new {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } }
            }
        };

        await JS.InvokeVoidAsync("chartInterop.renderChart", "priceChart", priceConfig);
        await JS.InvokeVoidAsync("chartInterop.renderChart", "lotChart", lotConfig);
    }
}
