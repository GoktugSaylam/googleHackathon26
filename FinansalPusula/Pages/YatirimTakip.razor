@page "/yatirim-takip"
@using FinansalPusula.Services
@using Microsoft.JSInterop
@inject YahooFinanceService YahooService
@inject PortfolioService PortfolioService
@inject BudgetService BudgetService
@inject NavigationManager NavManager
@inject IJSRuntime _jsRuntime
@implements IDisposable

<PageTitle>Dashboard - HisseMetre</PageTitle>

<div class="container-fluid animate-fade-in p-4">
    <div class="row g-4">
        <div class="col-xl-11 mx-auto">
            
            <!-- Üst Kartlar: Bakiye ve Portföy -->
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">PORTFÖY DEĞERİ (TL)</div>
                        <h2 class="fw-bold mb-0 text-white">₺@_totalValueTL.ToString("N0")</h2>
                        <span class="@_getMetricColor(_totalProfitLossPercentageTL) x-small fw-bold">
                            @(_totalProfitLossPercentageTL >= 0 ? "+" : "")%@_totalProfitLossPercentageTL.ToString("N1")
                            @(_totalProfitLossPercentageTL >= 0 ? "▲" : "▼")
                        </span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">PORTFÖY DEĞERİ (USD)</div>
                        <h2 class="fw-bold mb-0 text-white">$@_totalValueUSD.ToString("N0")</h2>
                        <span class="@_getMetricColor(_totalProfitLossPercentageTL) x-small fw-bold">
                            @(_totalProfitLossPercentageTL >= 0 ? "+" : "")%@_totalProfitLossPercentageTL.ToString("N1")
                            @(_totalProfitLossPercentageTL >= 0 ? "▲" : "▼")
                        </span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card h-100 border-primary-light position-relative overflow-hidden">
                        <div class="text-muted small fw-bold mb-2">CAGR (YILLIK BÜYÜME)</div>
                        <h2 class="fw-bold mb-1 @_getMetricColor(_cagr)">%@_cagr.ToString("N2")</h2>
                        <div class="text-muted x-small opacity-75">Geçen yıla oranla</div>
                        <i class="bi bi-graph-up position-absolute end-0 bottom-0 opacity-10 fs-1 me-2 mb-1"></i>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card h-100 border-primary-light position-relative overflow-hidden">
                        <div class="text-muted small fw-bold mb-2">XIRR (GERÇEK GETİRİ)</div>
                        <h2 class="fw-bold mb-1 @_getMetricColor(_xirr)">%@_xirr.ToString("N2")</h2>
                        <div class="mt-1">
                            @{
                                var _inflDiff = Math.Abs(_cagr - _targetInflation).ToString("N1");
                            }
                            @if (_cagr > _targetInflation)
                            {
                                <span class="badge bg-success bg-opacity-20 text-success-bright border border-success border-opacity-25" style="font-size: 0.65rem;">
                                    <i class="bi bi-trophy-fill me-1"></i> Enflasyonun %@_inflDiff üzerinde!
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-warning-custom shadow-sm" style="font-size: 0.65rem;">
                                    <i class="bi bi-info-circle me-1"></i> Enflasyonun %@_inflDiff altında kalındı.
                                </span>
                            }
                        </div>
                        <i class="bi bi-percent position-absolute end-0 bottom-0 opacity-10 fs-1 me-2 mb-1"></i>
                    </div>
                </div>
            </div>

            <!-- İkinci Durum Kartları -->
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">TL BAKİYE</div>
                        <h2 class="fw-bold mb-0 text-white">₺@BudgetService.CurrentIdleCash.ToString("N0")</h2>
                        <i class="bi bi-wallet2 position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2"></i>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">USD BAKİYE</div>
                        <h2 class="fw-bold mb-0 text-white">$@((BudgetService.CurrentIdleCash / (_usdTryRate > 0 ? _usdTryRate : 1)).ToString("N0"))</h2>
                        <i class="bi bi-currency-dollar position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2"></i>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="metric-card h-100 border-primary-light position-relative overflow-hidden">
                        <div class="text-muted small fw-bold mb-2">MAAŞ ÇARPANI (PORTFÖY/MAAŞ)</div>
                        <h2 class="fw-bold mb-0 text-white">@(BudgetService.MonthlySalary > 0 ? (_totalValueTL / BudgetService.MonthlySalary).ToString("N1") : "0")x</h2>
                        <div class="text-muted x-small opacity-75">Kaç maaşlık birikim yapıldı</div>
                        <i class="bi bi-person-badge position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-1"></i>
                    </div>
                </div>
            </div>

            <!-- Ana Tablo ve Grafik -->
            <div class="row g-4 mb-5">
                <div class="col-lg-8">
                    <div class="glass-card p-4 h-100">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Hisse Portföyü</h4>
                            <div class="badge-finance">@_portfolioQuotes.Count Varlık</div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-glass align-middle">
                                <thead>
                                    <tr>
                                        <th>Sembol</th>
                                        <th>Miktar</th>
                                        <th>Maliyet</th>
                                        <th>Güncel</th>
                                        <th>Değer</th>
                                        <th class="text-end">Kar / Zarar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stock in _portfolioQuotes)
                                    {
                                        <tr class="cursor-pointer hover-row" @onclick="() => NavigateToDetail(stock.Symbol)">
                                            <td class="fw-bold text-gradient">@stock.Symbol</td>
                                            <td>@stock.Quantity.ToString("N0")</td>
                                            <td>₺@stock.AverageCost.ToString("N2")</td>
                                            <td class="fw-bold">₺@stock.Price.ToString("N2")</td>
                                            <td class="fw-bold text-white">₺@stock.TotalValue.ToString("N2")</td>
                                            <td class="text-end">
                                                <div class="@(stock.ProfitLoss >= 0 ? "text-success-bright" : "text-danger-bright") fw-bold">
                                                    @(stock.ProfitLoss >= 0 ? "+" : "")₺@stock.ProfitLoss.ToString("N2")
                                                </div>
                                                <small class="text-muted x-small">(@stock.ProfitLossPercentage.ToString("N2")%)</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="glass-card p-4 h-100">
                        <h4 class="fw-bold mb-4">Varlık Dağılımı</h4>
                        <div class="p-3" style="min-height: 250px;">
                            <canvas id="distributionChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Son İşlemler -->
            <div class="row g-4">
                <div class="col-12">
                    <div class="glass-card p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Son İşlemler</h4>
                            <a href="/islemler" class="btn btn-sm btn-outline-primary border-white border-opacity-10 text-white px-3">Tümünü Gör</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-glass table-sm">
                                <thead>
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Sembol</th>
                                        <th>Tip</th>
                                        <th class="text-end">Adet</th>
                                        <th class="text-end">Birim Fiyat</th>
                                        <th class="text-end">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tx in _transactions.OrderByDescending(t => t.Tarih).Take(5))
                                    {
                                        <tr>
                                            <td>@tx.Tarih.ToString("dd.MM.yyyy")</td>
                                            <td class="fw-bold">@tx.Sembol</td>
                                            <td><span class="opacity-75">@tx.IslemTipi.ToString().ToUpper()</span></td>
                                            <td class="text-end">@tx.Adet.ToString("N0")</td>
                                            <td class="text-end">₺@tx.BirimFiyat.ToString("N2")</td>
                                            <td class="text-end fw-bold text-white">₺@tx.ToplamTutar.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-row:hover { background: rgba(255, 255, 255, 0.03); }
    .cursor-pointer { cursor: pointer; }
    .border-primary-light { border-top: 3px solid var(--accent-primary) !important; }
    .text-orange { color: #ff8a00; }
</style>

@code {
    private List<PortfolioTransaction> _transactions = new();
    private List<StockData> _portfolioQuotes = new();
    private decimal _totalValueTL = 0;
    private decimal _totalValueUSD = 0;
    private decimal _totalCostTL = 0;
    private double _totalProfitLossPercentageTL = 0;
    private decimal _usdTryRate = 33.0m; // Default fallback
    private double _cagr = 0;
    private double _xirr = 0;
    private double _targetInflation = 64.0;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            await BudgetService.LoadReportsAsync();
            _transactions = await PortfolioService.GetTransactionsAsync();
            await CalculatePortfolio();
        }
        catch (OperationCanceledException) { /* Navigation occurred */ }
        catch (Exception ex)
        {
            Console.WriteLine($"[YatirimTakip] Init error: {ex.Message}");
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task CalculatePortfolio()
    {
        var groups = _transactions
            .Where(t => t.IslemTipi == TransactionType.Alis || t.IslemTipi == TransactionType.Satis)
            .GroupBy(t => t.Sembol);

        _portfolioQuotes.Clear();
        
        // Paralel fiyat çekme için task listesi oluştur
        var tasks = groups.Select(async group => {
            var symbol = group.Key;
            var netQuantity = group.Sum(t => t.IslemTipi == TransactionType.Alis || t.IslemTipi == TransactionType.Buy ? t.Adet : -t.Adet);
            
            if (netQuantity <= 0) return null;

            var totalCost = group.Where(t => t.IslemTipi == TransactionType.Alis || t.IslemTipi == TransactionType.Buy).Sum(t => t.ToplamTutar);
            var buyQuantity = group.Where(t => t.IslemTipi == TransactionType.Alis || t.IslemTipi == TransactionType.Buy).Sum(t => t.Adet);
            var avgCost = buyQuantity > 0 ? totalCost / buyQuantity : 0;

            // Fiyat bilgisini çek (Token ile iptal edilebilir)
            var price = await YahooService.GetLivePriceAsync(symbol, _cts.Token);
            
            return new StockData
            {
                Symbol = symbol,
                Price = price,
                Quantity = netQuantity,
                AverageCost = avgCost
            };
        }).ToList();

        var results = await Task.WhenAll(tasks);
        _portfolioQuotes = results.Where(r => r != null).Cast<StockData>().ToList();

        _totalValueTL = _portfolioQuotes.Sum(s => s.TotalValue);
        _totalCostTL = _portfolioQuotes.Sum(s => s.Quantity * s.AverageCost);
        _totalProfitLossPercentageTL = _totalCostTL > 0 ? (double)((_totalValueTL / _totalCostTL) - 1m) * 100 : 0;
        
        // Canlı USD/TRY kurunu çek
        var liveUsdRate = await YahooService.GetLivePriceAsync("USDTRY=X", _cts.Token);
        if (liveUsdRate > 0) _usdTryRate = liveUsdRate;
        
        _totalValueUSD = _usdTryRate > 0 ? _totalValueTL / _usdTryRate : 0;

        // Metrikleri Backend'den Çek
        if (_totalValueTL > 0)
        {
            var metrics = await PortfolioService.GetPortfolioMetricsAsync(_totalValueTL);
            {
                _cagr = metrics.Cagr;
                _xirr = metrics.Xirr;
                _targetInflation = metrics.TargetInflation;
            }
        }

        // Grafikleri çiz
        await Task.Delay(100);
        await RenderDistributionChart();
    }

    private async Task RenderDistributionChart()
    {
        if (!_portfolioQuotes.Any()) return;

        try
        {
            var labels = _portfolioQuotes.Select(p => p.Symbol).ToArray();
            var data   = _portfolioQuotes.Select(p => (double)p.TotalValue).ToArray();
            var colors = new[] { "#00d1ff", "#00ff85", "#ff8a12", "#bf5af2", "#ffd60a", "#ff4d6d", "#8ac4ff" };

            // Chart.js interop'u çağır - chartInterop.js içinde tanımlı
            await _jsRuntime.InvokeVoidAsync("chartInterop.renderDoughnut",
                "distributionChart", labels, data, colors);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[YatirimTakip] Grafik çizim hatası: {ex.Message}");
        }
    }

    private void NavigateToDetail(string symbol)
    {
        NavManager.NavigateTo($"/hisse-detay/{symbol}");
    }

    private string _getMetricColor(double value)
    {
        if (value > 0) return "text-success-bright";
        if (value < 0) return "text-danger-bright";
        return "text-white";
    }
}
