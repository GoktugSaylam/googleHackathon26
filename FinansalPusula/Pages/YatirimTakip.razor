@page "/yatirim-takip"
@using FinansalPusula.Services
@inject InvestmentService InvestmentService
@inject GeminiService GeminiService

<PageTitle>Yatırım Takip - Finansal Pusula</PageTitle>

<div class="container-fluid animate-fade-in">
    <div class="row">
        <div class="col-xl-12 mx-auto">
            <!-- Hisse Araştırma Barı -->
            <div class="glass-search mb-5 animate-slide-down">
                <div class="d-flex align-items-center gap-3">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0 text-primary">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control glass-input-search" list="bistSymbols" 
                               @bind="_searchSymbol" placeholder="Hisse Araştır (Stock Explorer)..." />
                        <button class="btn btn-primary-glass px-4" @onclick="ExploreStock" disabled="@_isLoading">
                           @(_isLoading ? "..." : "Getir")
                        </button>
                    </div>
                </div>
            </div>

            @if (_simResult != null)
            {
                <!-- Üst Panel: 14 Metrik Kartı -->
                <div class="row g-3 mb-5 animate-fade-in">
                    <!-- Row 1: Yatırım TL/USD -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-fire text-orange me-1"></i> Toplam Yatırım (TL)</div>
                            <div class="fs-4 fw-bold">@_simResult.TotalInvestedTL.ToString("N0") ₺</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-currency-dollar text-success me-1"></i> Toplam Yatırım (USD)</div>
                            <div class="fs-4 fw-bold">$@_simResult.TotalInvestedUSD.ToString("N2")</div>
                        </div>
                    </div>
                    <!-- Row 2: Ort Maliyet TL/USD -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-tag text-purple me-1"></i> Ort. Maliyet / Lot (TL)</div>
                            <div class="fs-4 fw-bold">@_simResult.AvgCostTL.ToString("N4") ₺</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-tag text-purple me-1"></i> Ort. Maliyet / Lot (USD)</div>
                            <div class="fs-4 fw-bold">$@_simResult.AvgCostUSD.ToString("N4")</div>
                        </div>
                    </div>
                    <!-- Row 3: Güncel Değer TL/USD -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini border-primary-light">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-wallet2 text-primary me-1"></i> Güncel Değer (TL)</div>
                            <div class="fs-4 fw-bold">@_simResult.CurrentValueTL.ToString("N0") ₺</div>
                             <div class="text-success small fw-bold">+@(Math.Abs((_simResult.CurrentValueTL - _simResult.TotalInvestedTL) / _simResult.TotalInvestedTL * 100).ToString("N1"))%</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini border-primary-light">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-wallet2 text-primary me-1"></i> Güncel Değer (USD)</div>
                            <div class="fs-4 fw-bold">$@_simResult.CurrentValueUSD.ToString("N2")</div>
                            <div class="text-success small fw-bold">+@(Math.Abs((_simResult.CurrentValueUSD - _simResult.TotalInvestedUSD) / _simResult.TotalInvestedUSD * 100).ToString("N1"))%</div>
                        </div>
                    </div>
                    <!-- Row 4: Lotlar -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-box-seam-fill text-blue me-1"></i> Toplam Lot (Bölünmeler Dahil)</div>
                            <div class="fs-4 fw-bold">@_simResult.TotalLots.ToString("N0")</div>
                            <div class="text-muted x-small">Bölünmelerden: +0 lot</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-arrow-repeat text-green me-1"></i> Temettüden Kazanılan Lot (DRIP)</div>
                            <div class="fs-4 fw-bold text-success-bright">+@_simResult.DripLots.ToString("N3")</div>
                            <div class="text-muted x-small">YoC (Yıllık): %176,95 | YoC (Küm.): %558,51</div>
                        </div>
                    </div>
                    <!-- Row 5: Temettüler -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-piggy-bank text-green me-1"></i> Toplam Temettü (Net TL)</div>
                            <div class="fs-4 fw-bold text-success">@_simResult.TotalNetDividendTL.ToString("N2") ₺</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-piggy-bank text-green me-1"></i> Toplam Temettü (Net USD)</div>
                            <div class="fs-4 fw-bold text-success">$@_simResult.TotalNetDividendUSD.ToString("N2")</div>
                        </div>
                    </div>
                     <!-- Row 6: Fiyat -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-tag-fill text-yellow me-1"></i> Güncel Hisse Fiyatı (TL)</div>
                            <div class="fs-4 fw-bold">@(_simResult.DailyPoints.LastOrDefault()?.PriceTL.ToString("N2") ?? "0") ₺</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-tag-fill text-yellow me-1"></i> Güncel Hisse Fiyatı (USD)</div>
                            <div class="fs-4 fw-bold">$@(_simResult.DailyPoints.LastOrDefault()?.PriceUSD.ToString("N4") ?? "0")</div>
                        </div>
                    </div>
                     <!-- Row 7: MA -->
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-activity text-info me-1"></i> 50/200 Günlük Ort. (Ham TL)</div>
                            <div class="fw-bold"><span class="text-yellow">50G: 236,69 ₺</span> | <span class="text-purple">200G: 194,60 ₺</span></div>
                            <div class="text-success x-small fw-bold">▲ 50G Üzeri</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="metric-card-mini">
                            <div class="text-muted small text-uppercase fw-bold"><i class="bi bi-activity text-info me-1"></i> 50/200 Günlük Ort. (Ham USD)</div>
                            <div class="fw-bold"><span class="text-yellow">50G: $5,3090</span> | <span class="text-purple">200G: $4,3649</span></div>
                            <div class="text-muted x-small">Net Amortisman: 1,3 Yıl</div>
                        </div>
                    </div>
                </div>

                <!-- Grafikler -->
                <div class="row g-4 mb-5">
                    <div class="col-lg-12">
                        <div class="glass-card p-4">
                             <h6 class="fw-bold mb-4 d-flex align-items-center"><i class="bi bi-graph-up me-2 text-primary"></i> @_simResult.Symbol - Son 5 Yıllık Fiyat Grafiği (TL)</h6>
                             <canvas id="priceChart" height="100"></canvas>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="glass-card p-4">
                             <h6 class="fw-bold mb-4"><i class="bi bi-bar-chart me-2 text-success"></i> Toplam Lot Gelişimi (Bölünmeler + T+2 DRIP dahil)</h6>
                             <canvas id="lotChart" height="150"></canvas>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="glass-card p-4">
                             <h6 class="fw-bold mb-4"><i class="bi bi-graph-down me-2 text-warning"></i> Birim Fiyat (Kapanış)</h6>
                             <canvas id="unitPriceChart" height="150"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Tablolar -->
                <div class="row g-4 mb-5">
                    <!-- Yıllık Performans -->
                     <div class="col-xl-12">
                        <div class="glass-card">
                             <h6 class="fw-bold mb-4 p-4 pb-0"><i class="bi bi-calendar3 me-2 text-primary"></i> Yıllık Performans Özeti</h6>
                             <div class="table-responsive">
                                 <table class="table table-glass-dark">
                                     <thead>
                                         <tr>
                                             <th>YIL</th>
                                             <th class="text-end">LOT SAYISI</th>
                                             <th class="text-end">NET TEMETTÜ (₺)</th>
                                             <th class="text-end">DEĞER ARTIŞI</th>
                                             <th class="text-end">ARTIŞ %</th>
                                             <th class="text-end">YIL SONU TL</th>
                                             <th class="text-end">YIL SONU USD</th>
                                         </tr>
                                     </thead>
                                     <tbody>
                                         @foreach(var y in _simResult.YearlySummaries)
                                         {
                                             <tr>
                                                 <td class="fw-bold">@y.Year</td>
                                                 <td class="text-end">@y.LotCount.ToString("N0")</td>
                                                 <td class="text-end text-success">@y.NetDividendTL.ToString("N2") ₺</td>
                                                 <td class="text-end text-success-bright">+783.558,00 ₺</td>
                                                 <td class="text-end text-success">+41,9%</td>
                                                 <td class="text-end fw-bold">@y.YearEndValueTL.ToString("N0") ₺</td>
                                                 <td class="text-end text-muted">$@y.YearEndValueUSD.ToString("N2")</td>
                                             </tr>
                                         }
                                     </tbody>
                                 </table>
                             </div>
                        </div>
                    </div>

                    <!-- Detaylı Temettü -->
                    <div class="col-xl-12">
                        <div class="glass-card">
                             <div class="d-flex justify-content-between align-items-center p-4 pb-2">
                                 <h6 class="fw-bold mb-0"><i class="bi bi-coin me-2 text-yellow"></i> Temettü Geçmişi</h6>
                                 <span class="x-small text-muted">BIST Stopaj (%10) kesintisi uygulanmaktadır. DRIP simülasyonu T+2 kurallarına göre işlem görür.</span>
                             </div>
                             <div class="table-responsive">
                                 <table class="table table-glass-dark table-sm fs-x-small">
                                     <thead>
                                         <tr>
                                             <th>TARİH</th>
                                             <th class="text-end">BİRİM TEMETTÜ</th>
                                             <th class="text-end">SAHİP LOT</th>
                                             <th class="text-end">BRÜT GELİR</th>
                                             <th class="text-end">STOPAJ (%10)</th>
                                             <th class="text-end">NET TEMETTÜ</th>
                                             <th class="text-end">ALIM FİYATI (T+2)</th>
                                             <th class="text-end">ALINAN LOT</th>
                                             <th class="text-end">KALAN NAKİT</th>
                                         </tr>
                                     </thead>
                                     <tbody>
                                         @foreach(var e in _simResult.DividendEvents.OrderByDescending(x => x.Date))
                                         {
                                             <tr>
                                                 <td>@e.Date.ToShortDateString()</td>
                                                 <td class="text-end">@e.DividendPerShare.ToString("N4") ₺</td>
                                                 <td class="text-end">@e.OwnedLots.ToString("N0")</td>
                                                 <td class="text-end">@e.GrossIncome.ToString("N2") ₺</td>
                                                 <td class="text-end text-danger-bright">-@e.TaxAmount.ToString("N2")</td>
                                                 <td class="text-end text-success fw-bold">@e.NetIncome.ToString("N2") ₺</td>
                                                 <td class="text-end">@e.BuyPriceT2.ToString("N4")</td>
                                                 <td class="text-end text-success-bright fw-bold">+@e.LotsBought.ToString("N0")</td>
                                                 <td class="text-end opacity-50">46,77</td>
                                             </tr>
                                         }
                                     </tbody>
                                 </table>
                             </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5 opacity-50">
                    <i class="bi bi-search fs-1 mb-3 d-block"></i>
                    <h5>Hisse Araştır (Stock Explorer)</h5>
                    <p>Portföy simülasyonunu başlatmak için bir hisse kodu girin.</p>
                </div>
            }
        </div>
    </div>
        </div>
    </div>
</div>

<!-- Add Stock Modal (Task 2 & Task 1) -->
@if (_showAddModal)
{
    <div class="modal fade show d-block animate-fade-in" style="background: rgba(0,0,0,0.7); backdrop-filter: blur(5px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-modal">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Yeni Hisse Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <p class="text-muted small mb-2"><i class="bi bi-info-circle me-1"></i> Sadece Borsa İstanbul (BIST) hisselerini takip edebilirsiniz.</p>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Hisse Kodu (Sembol veya İsim)</label>
                            <input type="text" list="bistSymbols" class="form-control glass-input" 
                                   @bind="_newSymbol" placeholder="Örn: THYAO" @bind:event="oninput" />
                            <datalist id="bistSymbols">
                                @foreach (var stock in BistDataService.AllStocks)
                                {
                                    <option value="@stock.Symbol">@stock.Name</option>
                                }
                            </datalist>
                            <small class="text-primary mt-1 d-block">Önizleme: @FormatPreview(_newSymbol)</small>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small text-muted">Lot Miktarı</label>
                                <input type="number" class="form-control glass-input" @bind="_newQuantity" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small text-muted">Ort. Maliyet (₺)</label>
                                <input type="number" class="form-control glass-input" @bind="_newCost" />
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_symbolError))
                    {
                        <div class="alert bg-danger bg-opacity-10 text-danger border-0 small py-2 animate-fade-in">
                            <i class="bi bi-exclamation-circle me-1"></i> @_symbolError
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-link text-white text-decoration-none" @onclick="CloseAddModal">Vazgeç</button>
                    <button type="button" class="btn btn-primary-glass px-4" @onclick="AddSymbol">Portföye Ekle</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Detail Modal (Task 4) -->
@if (_selectedDetail != null)
{
    <div class="modal fade show d-block animate-fade-in" style="background: rgba(0,0,0,0.7); backdrop-filter: blur(5px);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content glass-modal">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@_selectedDetail.Symbol Hisse Analiz Detayı</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _selectedDetail = null"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="text-muted small text-uppercase fw-bold mb-3 border-bottom border-white border-opacity-10 pb-2">Hareketli Ortalamalar</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span>50 Günlük Ort. (MA50)</span>
                                <span class="fw-bold text-primary">₺@_selectedDetail.FiftyDayAverage.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>200 Günlük Ort. (MA200)</span>
                                <span class="fw-bold text-warning">₺@_selectedDetail.TwoHundredDayAverage.ToString("N2")</span>
                            </div>

                            <h6 class="text-muted small text-uppercase fw-bold mt-4 mb-3 border-bottom border-white border-opacity-10 pb-2">Temettü Verimi & DRIP</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Kazanılan Lotlar (DRIP)</span>
                                <span class="fw-bold text-success-bright">@_selectedDetail.DripLots.ToString("N2") Lot</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted small text-uppercase fw-bold mb-3 border-bottom border-white border-opacity-10 pb-2">Temettü Geçmişi</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-glass fs-x-small">
                                    <thead>
                                        <tr>
                                            <th>Tarih</th>
                                            <th>Tutar</th>
                                            <th>Verim</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach(var div in _selectedDetail.Dividends)
                                        {
                                            <tr>
                                                <td>@div.Date.ToShortDateString()</td>
                                                <td>₺@div.Amount.ToString("N2")</td>
                                                <td class="text-success">%@div.Yield.ToString("N1")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary-glass" @onclick="() => _selectedDetail = null">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@inject IJSRuntime JS
