@page "/"
@using FinansalPusula.Services
@inject BudgetService BudgetService
@inject InvestmentService InvestmentService
@inject NavigationManager Nav

<PageTitle>Ana Sayfa - Finansal Pusula</PageTitle>

<div class="container-fluid animate-fade-in">
    <div class="row">
        <div class="col-xl-10 offset-xl-1">
            
            <!-- Welcome Header -->
            <div class="d-flex justify-content-between align-items-center mb-5 mt-4">
                <div>
                    <h1 class="fw-bold mb-1 border-bottom border-primary border-opacity-10 pb-2">Merhaba, Finansal Pusulan Hazır! 🧭</h1>
                    <p class="text-muted mb-0 lead opacity-75">
                         Gemini AI destekli <strong>Gider Avcısı</strong> ile harcamalarını analiz et, <strong>Bütçe Kalkanı</strong> ile enflasyona karşı korun ve 
                         <strong>Borsa Takibi</strong> ile BIST portföyünü profesyonelce yönet. Finansal yolculuğunda akıllı yardımcın her an yanında.
                    </p>
                </div>
                <div class="p-3 rounded-circle bg-primary bg-opacity-10">
                    <i class="bi bi-person-circle fs-3 text-primary"></i>
                </div>
            </div>

            <!-- Dashboard Stats -->
            <div class="row g-4 mb-5">
                <!-- Salary & Cash Card -->
                <div class="col-md-3">
                    <div class="glass-card h-100 border-start border-primary border-4 p-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">Boşta Kalan Nakit</div>
                        <div class="display-6 fw-bold text-white mb-2">@BudgetService.CurrentIdleCash.ToString("C0")</div>
                        <div class="progress bg-white bg-opacity-10" style="height: 4px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 70%"></div>
                        </div>
                    </div>
                </div>

                <!-- Erosion Card -->
                <div class="col-md-3">
                    <div class="glass-card h-100 border-start border-danger border-4 p-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">Aylık Değer Kaybı</div>
                        <div class="display-6 fw-bold text-danger mb-2">-@BudgetService.CalculateMonthlyErosion().ToString("C0")</div>
                        <div class="text-muted small"><i class="bi bi-arrow-down-short"></i> Enflasyon Etkisi</div>
                    </div>
                </div>

                <!-- Expense Category Card -->
                <div class="col-md-3">
                    <div class="glass-card h-100 border-start border-warning border-4 p-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">En Büyük Gider</div>
                        <div class="display-6 fw-bold text-white mb-2">
                             @{
                                 var topCat = BudgetService.LastReport?.Expenses?
                                     .GroupBy(e => e.Category)
                                     .Select(g => new { Name = g.Key, Amount = g.Sum(e => e.Amount) })
                                     .OrderByDescending(x => x.Amount)
                                     .FirstOrDefault();
                                 @((topCat?.Name) ?? "N/A")
                             }
                        </div>
                        <div class="text-warning small fw-bold">
                            @((BudgetService.LastReport?.TotalSpending ?? 0).ToString("C0")) toplam
                        </div>
                    </div>
                </div>

                <!-- Portfolio Card -->
                <div class="col-md-3">
                    <div class="glass-card h-100 border-start border-success border-4 p-4">
                        <div class="text-muted small text-uppercase fw-bold mb-2">BIST Portföyü</div>
                        <div class="display-6 fw-bold text-white mb-2">Hisse: 4</div>
                        <div class="text-success small"><i class="bi bi-graph-up"></i> Aktif Takipte</div>
                    </div>
                </div>
            </div>

            <!-- Navigation Links -->
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="glass-card p-4 hover-scale cursor-pointer h-100" @onclick='() => Nav.NavigateTo("ekstre-yukle")'>
                        <div class="p-3 rounded-4 bg-primary bg-opacity-10 mb-3 d-inline-block">
                            <i class="bi bi-receipt-cutoff text-primary fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Gider Analizi Yap</h5>
                        <p class="text-muted small mb-0">Ekstre veya fatura yükleyerek Gemini ile harcamalarını kategorize et.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-card p-4 hover-scale cursor-pointer h-100" @onclick='() => Nav.NavigateTo("butce-kalkani")'>
                        <div class="p-3 rounded-4 bg-danger bg-opacity-10 mb-3 d-inline-block">
                            <i class="bi bi-shield-lock text-danger fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Bütçe Kalkanı</h5>
                        <p class="text-muted small mb-0">Paranın enflasyon karşısındaki erimesini durdurmak için strateji al.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-card p-4 hover-scale cursor-pointer h-100" @onclick='() => Nav.NavigateTo("yatirim-takip")'>
                        <div class="p-3 rounded-4 bg-success bg-opacity-10 mb-3 d-inline-block">
                            <i class="bi bi-graph-up-arrow text-success fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Yatırım Takip</h5>
                        <p class="text-muted small mb-0">BIST hisselerini takip et ve Gemini'dan portföy yorumu al.</p>
                    </div>
                </div>
            </div>

            <!-- AI Insight Section -->
            <div class="glass-card mt-5 p-5 border-primary border-opacity-10 overflow-hidden position-relative">
                <div class="position-absolute top-0 end-0 p-5 opacity-05">
                    <i class="bi bi-quote" style="font-size: 15rem;"></i>
                </div>
                <div class="row align-items-center">
                    <div class="col-lg-8 position-relative z-1">
                        <h3 class="fw-bold text-white mb-3">Günün Finansal İpucu</h3>
                        <p class="lead text-muted mb-0">
                            "En iyi yatırım, kendinize yaptığınız yatırımdır. Ancak enflasyondan korunmak için BIST hisseleri de fena bir başlangıç değildir!" 💡
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .hover-scale {
        transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .hover-scale:hover {
        transform: translateY(-5px);
        border-color: rgba(61, 142, 255, 0.4) !important;
    }
    .opacity-05 {
        opacity: 0.05;
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>
