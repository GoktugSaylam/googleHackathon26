@page "/hisse-detay/{Symbol}"
@using FinansalPusula.Services
@using System.Globalization
@inject YahooFinanceService YahooService
@inject IsYatirimService IsYatirim
@inject PortfolioService PortfolioService
@inject InvestmentService HistoricalDataService

<PageTitle>@Symbol Analiz - HisseMetre</PageTitle>

<div class="container-fluid animate-fade-in p-4">
    <div class="row g-4">
        <div class="col-xl-11 mx-auto">
            
            <!-- Üst Başlık ve Geri Dönüş -->
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                  <h1 class="fw-bold mb-1 text-gradient">@Symbol Detay Analizi</h1>
                  <p class="text-muted mb-0">Hisse özelinde gelişim, temettü ve teknik metrikler.</p>
                </div>
                <a href="/yatirim-takip" class="btn btn-outline-secondary border-white border-opacity-10 text-white">
                    <i class="bi bi-arrow-left me-2"></i> Dashboard'a Dön
                </a>
            </div>

            <!-- 8'li Metrik Grid Kartları -->
            <div class="row g-3 mb-5">
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">TOPLAM YATIRIM (TL)</div>
                        <h4 class="fw-bold mb-0">₺@_metrics.ToplamYatirimTL.ToString("N0")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">TOPLAM YATIRIM (USD)</div>
                        <h4 class="fw-bold mb-0">$@_metrics.ToplamYatirimUSD.ToString("N0")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">ORT. MALİYET / LOT</div>
                        <h4 class="fw-bold mb-0">₺@_metrics.OrtalamMaliyetLot.ToString("N2")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100 border-primary-light">
                        <div class="text-muted small fw-bold mb-2">GÜNCEL DEĞER (TL)</div>
                        <h4 class="fw-bold mb-0">₺@_metrics.GuncelDeger.ToString("N2")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">TOPLAM LOT</div>
                        <h4 class="fw-bold mb-0">@_metrics.ToplamLot.ToString("N0")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">DRIP (KAZANILAN LOT)</div>
                        <h4 class="fw-bold mb-0 text-success-bright">+@_metrics.DRIPLot.ToString("N3")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">TOPLAM TEMETTÜ</div>
                        <h4 class="fw-bold mb-0 text-success">₺@_metrics.ToplamTemettu.ToString("N2")</h4>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="metric-card h-100">
                        <div class="text-muted small fw-bold mb-2">SMA 50 / 200</div>
                        <h4 class="fw-bold mb-0">
                            <span class="text-info">@_metrics.SMA50.ToString("N1")</span> / 
                            <span class="text-purple">@_metrics.SMA200.ToString("N1")</span>
                        </h4>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Fiyat Çizgi Grafiği -->
                <div class="col-lg-8">
                    <div class="glass-card p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Fiyat & Portföy Gelişimi</h4>
                            <div class="btn-group btn-group-sm rounded-pill border border-white border-opacity-10 overflow-hidden">
                                <button class="btn btn-dark active px-3">TL</button>
                                <button class="btn btn-dark px-3 opacity-50">USD</button>
                            </div>
                        </div>
                        <div style="height: 400px;">
                            <canvas id="priceChart"></canvas>
                        </div>
                    </div>

                    <!-- Yıllık Temettü Bar Grafiği -->
                    <div class="glass-card p-4 mt-4">
                        <h4 class="fw-bold mb-4">Yıllık Temettü Akışı (Net TL)</h4>
                        <div style="height: 300px;">
                            <canvas id="dividendChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Detaylı Bilgiler (Temettücü Stili) -->
                <div class="col-lg-4">
                    <!-- Temettü Verimi & Büyüme -->
                    <div class="glass-card p-4 mb-4 bg-gradient-dark">
                        <h5 class="fw-bold mb-4 text-gradient">Verim & Performans</h5>
                        <div class="d-flex justify-content-between mb-3 border-bottom border-white border-opacity-5 pb-2">
                            <span class="text-muted">Son Temettü Verimi</span>
                            <span class="fw-bold text-success-bright">%@(_lastYield.ToString("N2"))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom border-white border-opacity-5 pb-2">
                            <span class="text-muted">Maliyet Verimi (YOC)</span>
                            <span class="fw-bold text-info">%@(_yieldOnCost.ToString("N2"))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom border-white border-opacity-5 pb-2">
                            <span class="text-muted">5 Yıllık CAGR (Tahmini)</span>
                            <span class="fw-bold text-warning">%18.4</span>
                        </div>
                        <div class="d-flex justify-content-between mb-0 pb-2">
                            <span class="text-muted">Temettü Skor (Pusula)</span>
                            <span class="fw-bold text-purple">8.2 / 10</span>
                        </div>
                    </div>

                    <!-- Temettü Geçmişi -->
                    <div class="glass-card p-4 h-auto">
                        <h4 class="fw-bold mb-4">Temettü Takvimi</h4>
                        <div class="table-responsive">
                            <table class="table table-glass table-sm v-align-middle">
                                <thead>
                                    <tr>
                                        <th>Tarih</th>
                                        <th class="text-end">Brüt (TL)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!_dividends.Any())
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center py-4 opacity-50">Kayıt bulunamadı.</td>
                                        </tr>
                                    }
                                    @foreach (var div in _dividends.Take(12))
                                    {
                                        <tr>
                                            <td class="text-muted small">@div.TARIH</td>
                                            <td class="text-end text-success-bright fw-bold">₺@div.HISSE_BASINA_TEMETTU_BRUT_TL</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-purple { color: #bf5af2 !important; }
    .border-primary-light { border-top: 3px solid var(--accent-primary) !important; }
    .v-align-middle td { vertical-align: middle; }
</style>

@code {
    [Parameter] public string Symbol { get; set; } = string.Empty;
    @inject IJSRuntime JS
    
    private StockDetailMetrics _metrics = new();
    private List<DividendData> _dividends = new();
    private SimulationResult? _simResult;
    private decimal _lastYield = 0;
    private decimal _yieldOnCost = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadHisseDetay();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_simResult != null)
        {
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        if (_simResult == null) return;

        // Fiyat Grafiği Hazırlığı
        var labels = _simResult.DailyPoints.Select(p => p.Date.ToString("MM/yy")).ToList();
        var prices = _simResult.DailyPoints.Select(p => p.PriceTL).ToList();

        var priceConfig = new
        {
            type = "line",
            data = new {
                labels = labels,
                datasets = new[] {
                    new {
                        label = "Fiyat (₺)",
                        data = prices,
                        borderColor = "#00d2ff",
                        backgroundColor = "rgba(0, 210, 255, 0.1)",
                        fill = true,
                        tension = 0.4,
                        borderWidth = 2,
                        pointRadius = 0
                    }
                }
            },
            options = new {
                responsive = true,
                maintainAspectRatio = false,
                scales = new {
                    y = new { grid = new { color = "rgba(255,255,255,0.05)" }, ticks = new { color = "#ffffff80" } },
                    x = new { grid = new { display = false }, ticks = new { color = "#ffffff80", maxTicksLimit = 12 } }
                },
                plugins = new { legend = new { display = false } }
            }
        };

        await JS.InvokeVoidAsync("chartInterop.renderChart", "priceChart", priceConfig);

        // Temettü Grafiği Preparatı
        var divLabels = _simResult.YearlySummaries.Select(s => s.Year.ToString()).ToList();
        var divValues = _simResult.YearlySummaries.Select(s => s.NetDividendTL).ToList();

        var divConfig = new
        {
            type = "bar",
            data = new {
                labels = divLabels,
                datasets = new[] {
                    new {
                        label = "Net Temettü (₺)",
                        data = divValues,
                        backgroundColor = "#34c759",
                        borderRadius = 4
                    }
                }
            },
            options = new {
                responsive = true,
                maintainAspectRatio = false,
                scales = new {
                    y = new { grid = new { color = "rgba(255,255,255,0.05)" }, ticks = new { color = "#ffffff80" } },
                    x = new { grid = new { display = false }, ticks = new { color = "#ffffff80" } }
                },
                plugins = new { legend = new { display = false } }
            }
        };

        await JS.InvokeVoidAsync("chartInterop.renderChart", "dividendChart", divConfig);
    }

    private async Task LoadHisseDetay()
    {
        _metrics.Sembol = Symbol;

        try 
        {
            var livePriceTask = YahooService.GetLivePriceAsync(Symbol);
            var smasTask = YahooService.GetSmaAsync(Symbol);
            var dividendsTask = IsYatirim.GetDividendsAsync(Symbol);
            var splitsTask = IsYatirim.GetSplitsAsync(Symbol);
            var transactionsTask = PortfolioService.GetTransactionsAsync();
            var historicalTask = HistoricalDataService.GetHistoricalDataAsync(Symbol, DateTime.Today.AddYears(-5), DateTime.Today);

            await Task.WhenAll(livePriceTask, smasTask, dividendsTask, splitsTask, transactionsTask, historicalTask);

            var livePrice = await livePriceTask;
            var smas = await smasTask;
            _dividends = await dividendsTask;
            var splitsRaw = await splitsTask;
            var allTxs = await transactionsTask;
            var history = await historicalTask;

            var hisseTxs = allTxs.Where(t => t.Sembol == Symbol && (t.IslemTipi == TransactionType.Alis || t.IslemTipi == TransactionType.Satis)).ToList();

            // Veri parse ve simülasyon mantığı (Aynı kaldı)
            var parsedDividends = new List<DividendHistory>();
            foreach (var d in _dividends)
            {
                if (DateTime.TryParseExact(d.TARIH, "dd.MM.yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out var date) &&
                    decimal.TryParse(d.HISSE_BASINA_TEMETTU_BRUT_TL.Replace(".", "").Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out var amount))
                {
                    parsedDividends.Add(new DividendHistory(date, amount, 0));
                }
            }

            var parsedSplits = new List<SplitInfo>();
            foreach (var s in splitsRaw)
            {
                if (DateTime.TryParseExact(s.TARIH, "dd.MM.yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
                {
                    if (decimal.TryParse(s.BEDELSIZ_ARTIRIM_ORANI.Replace(".", "").Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out var oran) && oran > 0)
                    {
                        var multiplier = 1 + (oran / 100m);
                        parsedSplits.Add(new SplitInfo(date, $"{multiplier * 1000}:1000"));
                    }
                }
            }

            var simTxs = hisseTxs.Select(t => new TransactionRecord 
            { 
                Id = Guid.Parse(t.Id.Length == 36 ? t.Id : Guid.NewGuid().ToString()), 
                Symbol = t.Sembol, 
                Date = t.Tarih, 
                Quantity = t.Adet, 
                Price = t.BirimFiyat, 
                Type = t.IslemTipi == TransactionType.Satis ? TransactionType.Sell : TransactionType.Buy 
            }).ToList();

            _simResult = PortfolioSimulator.Simulate(Symbol, history, parsedDividends, parsedSplits, simTxs);

            // Metrik Atamaları
            _metrics.SMA50 = smas.sma50;
            _metrics.SMA200 = smas.sma200;
            _metrics.ToplamYatirimTL = _simResult.TotalInvestedTL;
            _metrics.ToplamYatirimUSD = _simResult.TotalInvestedUSD;
            _metrics.GuncelDeger = _simResult.CurrentValueTL;
            _metrics.ToplamLot = _simResult.TotalLots;
            _metrics.DRIPLot = _simResult.DripLots;
            _metrics.ToplamTemettu = _simResult.TotalNetDividendTL;
            _metrics.OrtalamMaliyetLot = _simResult.AvgCostTL;

            if (livePrice > 0) {
                var lastDiv = parsedDividends.OrderByDescending(d => d.Date).FirstOrDefault();
                if (lastDiv != null) _lastYield = (lastDiv.Amount / livePrice) * 100;
                if (_metrics.OrtalamMaliyetLot > 0 && lastDiv != null) _yieldOnCost = (lastDiv.Amount / _metrics.OrtalamMaliyetLot) * 100;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Detay Yükleme Hatası: {ex.Message}");
        }

        StateHasChanged();
    }
}
