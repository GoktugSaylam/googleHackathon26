@page "/ekstre-yukle"
@using FinansalPusula.Services
@using System.Net.Http.Json
@using System.Text.Json
@inject BudgetService BudgetService
@inject HttpClient Http

<PageTitle>Ekstre Yükle - Finansal Pusula</PageTitle>

<div class="container-fluid animate-fade-in">
    <div class="row">
        <div class="col-xl-8 offset-xl-2">
            
            <div class="d-flex align-items-center mb-5 mt-4">
                <div class="p-3 rounded-4 bg-primary bg-opacity-10 me-4">
                    <i class="bi bi-receipt-cutoff text-primary fs-2"></i>
                </div>
                <div>
                    <h1 class="fw-bold mb-1">Gider ve Ekstre Analizi</h1>
                    <p class="text-muted mb-0">Yapay zeka desteği ile harcamalarınızı saniyeler içinde dijitalleştirin.</p>
                </div>
            </div>

            <div class="glass-card mb-5">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <h4 class="fw-bold mb-3 text-white">Yeni Belge Yükle</h4>
                        <p class="text-white text-opacity-75 mb-4">Banka ekstresi, market fişi veya faturalarınızı (JPEG, PNG, PDF) buraya yükleyerek analizi başlatın.</p>
                        
                        <div class="mb-4">
                            <label class="btn btn-primary-glass w-100 py-3 cursor-pointer">
                                <i class="bi bi-cloud-arrow-up me-2"></i> Dosyaları Seçin
                                <InputFile OnChange="HandleFileSelected" class="d-none" accept=".jpg,.jpeg,.png,.pdf" multiple />
                            </label>
                        </div>
                        
                        <div class="d-flex gap-3">
                            <span class="badge-finance"><i class="bi bi-check2-circle me-1"></i> OCR Desteği</span>
                            <span class="badge-finance"><i class="bi bi-check2-circle me-1"></i> Gemini 2.5 Flash</span>
                        </div>
                    </div>
                    <div class="col-md-5 d-none d-md-block text-center border-start border-white border-opacity-10">
                        <i class="bi bi-file-earmark-text text-primary opacity-25" style="font-size: 8rem;"></i>
                    </div>
                </div>
            </div>

            @if (_isProcessing)
            {
                <div class="glass-card mb-5 animate-fade-in">
                    <div class="spinner-container">
                        <div class="custom-spinner"></div>
                        <h5 class="fw-bold mt-2">@_statusMessage</h5>
                        <p class="text-muted small">Lütfen bekleyin, verileriniz işleniyor...</p>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert bg-danger bg-opacity-10 border border-danger border-opacity-20 text-danger rounded-4 p-4 animate-fade-in" role="alert">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Bir Hata Oluştu</h6>
                            <span>@_errorMessage</span>
                        </div>
                    </div>
                </div>
            }

            @if (BudgetService.AllReports.Any())
            {
                <div class="animate-fade-in">
                    <!-- Dashboard Filters -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-bold mb-0">Harcama Arşivi</h4>
                        <div class="d-flex align-items-center gap-3">
                            <label class="small text-muted mb-0">Dönem Seçin:</label>
                            <select class="form-select glass-input py-1 px-4 border-opacity-20 shadow-sm" @onchange="OnPeriodChanged" style="width: auto; min-width: 150px;">
                                <option value="Hepsi">Tüm Harcamalar</option>
                                @foreach (var p in BudgetService.AllReports.Select(r => r.Period).Distinct().OrderByDescending(p => p))
                                {
                                    <option value="@p">@p Dönemi</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Summary Card -->
                    <div class="glass-card mb-4 overflow-hidden position-relative">

                        <div class="row">
                            <div class="col-md-8">
                                <span class="badge bg-primary bg-opacity-25 text-primary mb-3 px-3 py-2 rounded-3">Yapay Zeka Özeti (@(_selectedPeriod == "Hepsi" ? "Genel" : _selectedPeriod))</span>
                                <h3 class="fw-bold mb-3">Finansal Danışman Notu</h3>
                                <p class="lead text-main opacity-75">@GetActiveSummary()</p>
                            </div>
                            <div class="col-md-4 text-md-end mt-4 mt-md-0 d-flex flex-column justify-content-center">
                                <small class="text-muted text-uppercase fw-bold letter-spacing-1">Toplam Harcama</small>
                                <h1 class="fw-bold text-gradient mb-0">@GetTotalSpending().ToString("C2")</h1>
                            </div>
                        </div>
                    </div>

                    @if (GetActiveSubscriptions().Any())
                    {
                        <div class="glass-card mb-4 border-warning border-opacity-20">
                            <h5 class="fw-bold mb-4 d-flex align-items-center">
                                <i class="bi bi-arrow-repeat text-warning me-2"></i> Aktif Abonelikler
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-glass align-middle">
                                    <thead>
                                        <tr>
                                            <th>Hizmet</th>
                                            <th>Maliyet</th>
                                            <th>Alternatif Öneri</th>
                                            <th>Tasarruf Tavsiyesi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sub in GetActiveSubscriptions())
                                        {
                                            <tr>
                                                <td class="fw-bold">@sub.Name</td>
                                                <td>@sub.Cost.ToString("C2")</td>
                                                <td><span class="text-primary fw-medium">@sub.Alternative</span></td>
                                                <td class="text-muted small">@sub.SavingsAdvice</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Expense Details -->
                    <div class="glass-card mb-5">
                        <h5 class="fw-bold mb-4 d-flex align-items-center">
                            <i class="bi bi-list-check text-primary me-2"></i> Harcama Detayları
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-glass">
                                <thead>
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Dönem</th>
                                        <th>Mağaza/Firma</th>
                                        <th>Kategori</th>
                                        <th class="text-end">Tutar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in GetFilteredExpenses())
                                    {
                                        <tr>
                                            <td class="text-muted small">@item.Date</td>
                                            <td class="text-muted small">@(item.Donem ?? "-")</td>
                                            <td class="fw-medium">@item.Merchant</td>
                                            <td><span class="badge-finance">@item.Category</span></td>
                                            <td class="text-end fw-bold">@item.Amount.ToString("C2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private string _statusMessage = "";
    private string? _errorMessage;
    private string _selectedPeriod = "Hepsi";
    protected override async Task OnInitializedAsync()
    {
        await BudgetService.LoadReportsAsync();
    }

    private void OnPeriodChanged(ChangeEventArgs e)
    {
        _selectedPeriod = e.Value?.ToString() ?? "Hepsi";
    }

    private List<ExpenseItem> GetFilteredExpenses()
    {
        IEnumerable<ExpenseItem> expenses;

        if (_selectedPeriod == "Hepsi")
        {
            expenses = BudgetService.AllReports
                .SelectMany(r => r.Expenses ?? new List<ExpenseItem>());
        }
        else
        {
            expenses = BudgetService.AllReports
                .Where(r => r.Period == _selectedPeriod)
                .SelectMany(r => r.Expenses ?? new List<ExpenseItem>());
        }

        return expenses
            .Where(e => e != null)
            .OrderByDescending(GetExpenseSortDate)
            .ThenBy(e => e.Merchant)
            .ToList();
    }

    private static DateTime GetExpenseSortDate(ExpenseItem expense)
    {
        if (expense == null)
        {
            return DateTime.MinValue;
        }

        if (TryParseExpenseDate(expense.Date, out var parsedDate))
        {
            return parsedDate;
        }

        if (TryParseExpenseDate(expense.Donem, out parsedDate))
        {
            return parsedDate;
        }

        return DateTime.MinValue;
    }

    private static bool TryParseExpenseDate(string? rawDate, out DateTime parsed)
    {
        parsed = DateTime.MinValue;

        if (string.IsNullOrWhiteSpace(rawDate))
        {
            return false;
        }

        var normalized = rawDate.Trim();
        var formats = new[]
        {
            "dd.MM.yyyy",
            "d.M.yyyy",
            "dd/MM/yyyy",
            "d/M/yyyy",
            "dd-MM-yyyy",
            "d-M-yyyy",
            "yyyy-MM-dd",
            "yyyy/MM/dd",
            "MM-yyyy",
            "MM.yyyy"
        };

        if (DateTime.TryParseExact(
            normalized,
            formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out parsed))
        {
            return true;
        }

        return DateTime.TryParse(
            normalized,
            System.Globalization.CultureInfo.GetCultureInfo("tr-TR"),
            System.Globalization.DateTimeStyles.None,
            out parsed);
    }

    private List<SubscriptionItem> GetActiveSubscriptions()
    {
        IEnumerable<SubscriptionItem> subscriptions;

        if (_selectedPeriod == "Hepsi")
        {
            subscriptions = BudgetService.AllReports
                .SelectMany(r => r.Subscriptions ?? new List<SubscriptionItem>());
        }
        else
        {
            subscriptions = BudgetService.AllReports
                .Where(r => r.Period == _selectedPeriod)
                .SelectMany(r => r.Subscriptions ?? new List<SubscriptionItem>());
        }

        return subscriptions
            .Where(s => s != null && !string.IsNullOrWhiteSpace(s.Name))
            .GroupBy(s => s.Name!.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g => new SubscriptionItem
            {
                Name = g.FirstOrDefault(s => !string.IsNullOrWhiteSpace(s.Name))?.Name?.Trim() ?? g.Key,
                Cost = g.Sum(s => s.Cost),
                Alternative = g.Select(s => s.Alternative).FirstOrDefault(a => !string.IsNullOrWhiteSpace(a)),
                SavingsAdvice = g.Select(s => s.SavingsAdvice).FirstOrDefault(a => !string.IsNullOrWhiteSpace(a))
            })
            .OrderByDescending(s => s.Cost)
            .ToList();
    }

    private decimal GetTotalSpending() => GetFilteredExpenses().Sum(e => e.Amount);

    private string GetActiveSummary()
    {
        if (_selectedPeriod == "Hepsi") 
            return "Tüm dönemlerin ortalama harcama analizi yapılıyor. Genel tasarruf stratejilerini aşağıda bulabilirsiniz.";
            
        return BudgetService.AllReports.FirstOrDefault(r => r.Period == _selectedPeriod)?.SummaryAdvice 
               ?? "Seçili dönem için analiz beyanı bulunamadı.";
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _isProcessing = true;
        _errorMessage = null;

        try
        {
            var files = e.GetMultipleFiles(20);
            if (files.Count == 0)
            {
                return;
            }

            var processedCount = 0;
            var failedFiles = new List<string>();
            string? lastPeriod = null;

            for (var index = 0; index < files.Count; index++)
            {
                var file = files[index];

                try
                {
                    _statusMessage = $"{index + 1}/{files.Count}: Dosya okunuyor ({file.Name})...";
                    await SafeRefreshUiAsync();

                    using var stream = file.OpenReadStream(10 * 1024 * 1024);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    var fileBytes = ms.ToArray();

                    _statusMessage = $"{index + 1}/{files.Count}: Belge sunucuya gönderildi, analiz ediliyor ({file.Name})...";
                    await SafeRefreshUiAsync();

                    var response = await Http.PostAsJsonAsync("api/ai/analyze-expenses", new AnalyzeExpensesRequest
                    {
                        FileBytesBase64 = Convert.ToBase64String(fileBytes),
                        FileName = file.Name
                    });

                    if (!response.IsSuccessStatusCode)
                    {
                        ApiProblemDetails? problem = null;
                        var rawError = await response.Content.ReadAsStringAsync();
                        try
                        {
                            if (!string.IsNullOrWhiteSpace(rawError))
                            {
                                problem = JsonSerializer.Deserialize<ApiProblemDetails>(rawError, new JsonSerializerOptions
                                {
                                    PropertyNameCaseInsensitive = true
                                });
                            }
                        }
                        catch
                        {
                            // Fall through to raw error text
                        }

                        var detail = problem?.Detail ?? problem?.Message ?? problem?.Title ?? rawError;
                        failedFiles.Add(string.IsNullOrWhiteSpace(detail)
                            ? $"{file.Name}: Analiz servisi hatası {(int)response.StatusCode}"
                            : $"{file.Name}: {detail}");
                        continue;
                    }

                    _statusMessage = $"{index + 1}/{files.Count}: Analiz sonucu alınıyor ({file.Name})...";
                    await SafeRefreshUiAsync();

                    var rawReport = await response.Content.ReadAsStringAsync();
                    ExpenseReport? report;
                    try
                    {
                        report = JsonSerializer.Deserialize<ExpenseReport>(rawReport, new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true
                        });
                    }
                    catch (JsonException)
                    {
                        failedFiles.Add($"{file.Name}: Analiz sonucu beklenen formatta dönmedi.");
                        continue;
                    }

                    if (report == null)
                    {
                        failedFiles.Add($"{file.Name}: Analiz sonucu işlenemedi.");
                        continue;
                    }

                    await BudgetService.AddOrUpdateReport(report);
                    lastPeriod = report.Period;
                    processedCount++;
                }
                catch (TaskCanceledException)
                {
                    failedFiles.Add($"{file.Name}: İstek zaman aşımına uğradı.");
                }
                catch (Exception ex)
                {
                    failedFiles.Add($"{file.Name}: {ex.Message}");
                }
            }

            if (processedCount > 0)
            {
                _selectedPeriod = files.Count > 1 ? "Hepsi" : (lastPeriod ?? "Hepsi");
            }

            if (failedFiles.Count > 0)
            {
                var failedPreview = string.Join(" | ", failedFiles.Take(2));
                _errorMessage = processedCount == 0
                    ? $"Seçilen dosyalar işlenemedi. {failedPreview}"
                    : $"{processedCount} dosya analiz edildi, {failedFiles.Count} dosya işlenemedi. {failedPreview}";
            }
            else if (processedCount == 0)
            {
                _errorMessage = "Dosya seçimi yapılmadı.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Beklenmedik bir hata oluştu: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            _statusMessage = "";
            await SafeRefreshUiAsync();
        }
    }

    private async Task SafeRefreshUiAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Page was disposed during a long-running request.
        }
        catch (InvalidOperationException)
        {
            // Renderer/context may no longer be available.
        }
    }

    private sealed class AnalyzeExpensesRequest
    {
        public string FileBytesBase64 { get; set; } = string.Empty;
        public string? FileName { get; set; }
    }

    private sealed class ApiProblemDetails
    {
        public string? Title { get; set; }
        public string? Detail { get; set; }
        public string? Message { get; set; }
    }
}
